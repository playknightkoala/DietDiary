# Docker Compose 環境變數範本
# 使用方式：cp .env.example .env，填入實際值後執行 docker compose up -d
# 注意：.env 含密碼，請勿提交進版本控制（加入 .gitignore）

# JWT 簽章秘鑰（請換成隨機值：openssl rand -hex 32）
JWT_SECRET=please-change-this-secret

# ===== Gmail SMTP 寄信設定 =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# 寄件用的 Gmail 帳號
SMTP_USER=your@gmail.com
# Gmail「應用程式密碼」16 碼（不是登入密碼！）
# 取得方式：Google 帳戶 → 安全性 → 開啟兩步驟驗證 → 應用程式密碼 → 建立
SMTP_PASS=
# 寄件者顯示信箱（可留空，預設同 SMTP_USER）
SMTP_FROM=

# 收「新帳號待審核」通知信的管理員信箱
ADMIN_EMAIL=admin@example.com

# 對外網址（管理員信中開通連結的網域，要讓管理員點得到）
APP_URL=http://localhost:8080

# ===== AI 功能（eland LLM Gateway）=====
# 呼叫 gateway 的 Bearer token；未填則全站 AI 功能停用。
# 權限採「逐一開放」：管理者需在後台為個別會員開啟 AI 功能，並非全體可用。
LLM_TOKEN=
# gateway 網址（預設打 eigw；LiteLLM，OpenAI 相容）
LLM_BASE_URL=https://eigw.elandai.cloud
# 模型：OCR／看圖用「視覺」模型（預設 gemma-4-31b，已修復、單次請求可吃多張圖，實測 10 張 OK）；
#       純文字評語用文字模型（預設 gemma-4-12b，不吃圖）。
#       貼文含照片的評語會自動改用 LLM_OCR_MODEL；gemma-4-e4b、olmocr 可作視覺備援。
LLM_OCR_MODEL=gemma-4-31b
LLM_COMMENT_MODEL=gemma-4-12b
# 備援模型：主模型壞掉（HTTP 錯誤／逾時）時自動改用，結果會標示實際使用的模型
LLM_OCR_FALLBACK_MODEL=gemma-4-e4b
LLM_COMMENT_FALLBACK_MODEL=gemma-4-e4b
# AI 評語是否附上照片（送進視覺模型）。留空或 true＝附上貼文「全部」照片一併參考；
# 設 false 可退回純文字模式（省視覺模型負載，評語只依敘述＋份數＋當日累計＋目標）。
LLM_COMMENT_USE_PHOTO=true
