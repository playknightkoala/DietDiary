# Docker Compose 環境變數範本
# 使用方式：cp .env.example .env，填入實際值後執行 docker compose up -d
# 注意：.env 含密碼，請勿提交進版本控制（加入 .gitignore）

# JWT 簽章秘鑰（請換成隨機值：openssl rand -hex 32）
JWT_SECRET=please-change-this-secret

# ===== Gmail SMTP 寄信設定 =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# 寄件用的 Gmail 帳號
SMTP_USER=your@gmail.com
# Gmail「應用程式密碼」16 碼（不是登入密碼！）
# 取得方式：Google 帳戶 → 安全性 → 開啟兩步驟驗證 → 應用程式密碼 → 建立
SMTP_PASS=
# 寄件者顯示信箱（可留空，預設同 SMTP_USER）
SMTP_FROM=

# 收「新帳號待審核」通知信的管理員信箱
ADMIN_EMAIL=admin@example.com

# 對外網址（管理員信中開通連結的網域，要讓管理員點得到）
APP_URL=http://localhost:8080

# ===== AI 功能（eland LLM Gateway）=====
# 呼叫 gateway 的 Bearer token；未填則全站 AI 功能停用。
# 權限採「逐一開放」：管理者需在後台為個別會員開啟 AI 功能，並非全體可用。
LLM_TOKEN=
# gateway 網址（預設打 eigw；LiteLLM，OpenAI 相容）
LLM_BASE_URL=https://eigw.elandai.cloud
# 模型：看圖只用 LLM_OCR_MODEL（預設 gemma-4-31b，單次請求可吃多張圖；
#       e4b 看圖品質不佳且僅能讀一張，不作視覺備援）；純文字評語用 gemma-4-12b。
#       31b 故障時：評語自動降級為純文字（12b → e4b）並標示「未參考照片」；OCR 回報稍後再試。
LLM_OCR_MODEL=gemma-4-31b
LLM_COMMENT_MODEL=gemma-4-12b
# 純文字備援模型：12b 壞掉時自動改用，結果會標示實際使用的模型
LLM_COMMENT_FALLBACK_MODEL=gemma-4-e4b
# 單次模型呼叫逾時（毫秒，預設 45000）；主模型卡住逾時後會換備援模型再試一次
LLM_TIMEOUT_MS=45000

# ===== 網路搜尋（Tavily，選用）=====
# AI 查證用的 Tavily API key（https://app.tavily.com 免費註冊，1,000 credits/月、不綁卡不計費）。
# 未填則搜尋相關功能全部停用（OCR 純視覺估算、評語不查證、營養師查詢助手回覆未設定），主功能不受影響。
# 啟用後：OCR 認出品牌品項且知識庫沒有時會搜營養標示校正份數；評語遇到不熟悉食材可查證；
#         營養師頁面多「營養查詢助手」。結果快取 90 天，同品項只搜一次。
TAVILY_API_KEY=
# 本地每月額度閘門（預設 950，留 50 緩衝）：達到後當月自動停用搜尋、其餘功能照舊
TAVILY_MONTHLY_BUDGET=950

# ===== 共用菜色知識庫（embedding 參考，選用）=====
# 總開關（預設 false）。開啟後 OCR 會查「相似菜色的社群共識份數」當估算依據。
# 需搭配 embedding 服務；記憶體吃緊時設回 false，主功能完全不受影響。
AI_KB_ENABLED=true
# embedding 服務位址（文字＋圖片向量）。同機用 compose profile：http://embedder:8900；
# 另一台則填 http://<那台IP>:8900。未填時知識庫自動停用。
# 啟用方式：docker compose --profile embed up -d --build
AI_EMBED_URL=http://127.0.0.1:8900
